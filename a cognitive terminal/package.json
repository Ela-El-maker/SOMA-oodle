{
  "name": "command-ct",
  "private": true,
  "version": "1.0.0",
  "description": "Command (CT) - Cognitive Terminal for SOMA",
  "author": "Barry",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port 5173",
    "server": "node server/index.cjs",
    "dev:both": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run server\" \"npm run dev\" \"wait-on http://localhost:3001 && wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "start": "electron .",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "command:dev": "cross-env NODE_ENV=development APP_MODE=command electron ."
  },
  "build": {
    "appId": "com.soma.command",
    "productName": "Command",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@ricky0123/vad-node": "^0.0.3",
    "bonjour": "^3.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "whisper-node": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  }
}
