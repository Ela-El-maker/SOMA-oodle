{
  "name": "soma-interface",
  "private": true,
  "version": "1.0.0",
  "description": "SOMA Interface - Voice interface for SOMA cognitive engine",
  "author": "Barry",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:start": "electron .",
    "electron:quick": "concurrently \"vite --mode electron\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:build:win": "vite build --mode electron && electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "electron-store": "^8.1.0",
    "elevenlabs": "^0.16.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.soma.interface",
    "productName": "SOMA Interface",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
